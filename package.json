{
  "name": "ivano-pms",
  "version": "1.0.0",
  "private": true,
  "description": "Ivano Hospitality PMS — Next.js manager app, webhooks, Convex backend.",
  "scripts": {
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:web": "pnpm --filter @ivano/web test",
    "lint": "eslint convex",
    "lint:convex": "eslint convex",
    "dev": "pnpm web:dev",
    "web:dev": "pnpm --filter @ivano/web dev",
    "build": "pnpm build:web",
    "build:web": "pnpm --filter @ivano/web build",
    "build:all": "pnpm -r build",
    "seed": "npx convex run seed:seedDemoData --push"
  },
  "license": "ISC",
  "packageManager": "pnpm@10.29.3",
  "devDependencies": {
    "@convex-dev/eslint-plugin": "^1.1.1",
    "@vitest/coverage-v8": "^3.2.4",
    "convex": "^1.34.1",
    "convex-test": "^0.0.53",
    "eslint": "^9.39.2",
    "tsx": "^4.21.0",
    "typescript": "5.9.3",
    "typescript-eslint": "^8.50.0",
    "vitest": "^3.2.4"
  },
  "dependencies": {
    "convex-helpers": "^0.1.119"
  }
}

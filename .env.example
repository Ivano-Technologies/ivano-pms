# Ivano PMS environment variables

# --- Convex (apps/web) ---
NEXT_PUBLIC_CONVEX_URL=
CONVEX_URL=

# --- Convex dashboard (not apps/web) ---
# CLERK_JWT_ISSUER_DOMAIN=https://your-app.clerk.accounts.dev

# --- Shared secret (Convex dashboard AND apps/web/.env.local) ---
# Generate: openssl rand -hex 32
INTERNAL_JOB_SECRET=

# --- Channel token encryption (Convex dashboard only) ---
# Generate: openssl rand -base64 32
CHANNEL_TOKEN_ENCRYPTION_KEY=

# --- Clerk (apps/web) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=
CLERK_SECRET_KEY=

# --- Webhooks (Next.js POST /api/webhooks) ---
WEBHOOK_SECRET=
DEFAULT_PROPERTY_ID=

# --- Next.js ---
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Channel provider tokens (Week 2+ — provider-specific adapters)
WHATSAPP_ACCESS_TOKEN=
TELEGRAM_BOT_TOKEN=
# Convex: TELEGRAM_BOT_USERNAME (without @, e.g. IvanoPMSBot)
TELEGRAM_BOT_USERNAME=
# Convex: TELEGRAM_WEBHOOK_URL (e.g. https://pms.techivano.com/api/webhooks/telegram)
# Convex + Vercel: TELEGRAM_WEBHOOK_SECRET (setWebhook secret_token + X-Telegram-Bot-Api-Secret-Token)
TELEGRAM_WEBHOOK_SECRET=
# Vercel + Cloudflare Email Worker: shared secret (X-Email-Webhook-Secret header)
EMAIL_WEBHOOK_SECRET=
INSTAGRAM_VERIFY_TOKEN=
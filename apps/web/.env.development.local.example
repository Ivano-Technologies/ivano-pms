# Copy to apps/web/.env.development.local (gitignored via .env.*)
# Loaded by `next dev` only — overrides production-oriented values in .env.local.
#
# Clerk: use the PMS **Development** instance keys (Dashboard → Development → API Keys).
# Dev Frontend API: striking-rodent-37.clerk.accounts.dev
#
# After copying, replace placeholders below. Do not commit real keys.

# --- Clerk (development instance only) ---
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME
CLERK_SECRET_KEY=sk_test_REPLACE_ME

# Optional aliases if your tooling reads non-NEXT_PUBLIC names
CLERK_PUBLISHABLE_KEY=pk_test_REPLACE_ME

# Local URLs (required for Clerk dev keys — pk_test_ does not work on pms.techivano.com)
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_CLERK_SIGN_IN_URL=http://localhost:3000/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=http://localhost:3000/sign-up

# Convex dev deployment must use the **dev** Clerk JWT issuer (Convex dashboard, dev deployment):
# CLERK_JWT_ISSUER_DOMAIN=https://striking-rodent-37.clerk.accounts.dev
# (Set in Convex dashboard for your dev deployment — not in this file unless you mirror it locally.)

# --- Auth recording / local screenshots (step 2: create user in dev instance first) ---
# DEV_SMOKE_EMAIL=your-dev-manager@example.com
